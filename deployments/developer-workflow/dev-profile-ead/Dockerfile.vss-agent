#
# Custom VSS Agent image for the EAD (Extended Audio Description) profile.
#
# Extends the official NVIDIA VSS agent image with the EAD tool suite:
#   - caption_parser     : VTT/SRT subtitle parser
#   - scene_segmenter    : sensitivity-controlled video segmentation
#   - visual_describer   : VLM-based per-segment EAD description generator
#   - chapter_generator  : LLM-based chapter title and summary creator
#   - metadata_enricher  : JSON-LD VideoObject metadata assembler
#   - ead_formatter      : WebVTT + TTML output renderer
#   - ead_agent          : end-to-end pipeline orchestrator
#
# Strategy: copy updated .py files directly into the existing vss_agents
# package directory inside the container. No pip install is needed because
# the NAT entry points already point to vss_agents.tools.register and
# vss_agents.agents.register — our updated register.py files import both
# the original tools and the new EAD tools.
#
# Build context must be the repository root so agent/ is accessible:
#   docker build -f deployments/developer-workflow/dev-profile-ead/Dockerfile.vss-agent \
#                -t vss-agent-ead:3.1.0 .

ARG VSS_AGENT_VERSION=3.1.0
FROM nvcr.io/nvidia/vss-core/vss-agent:${VSS_AGENT_VERSION}

# Stage the updated vss_agents source and the install helper
COPY agent/src/vss_agents/ /tmp/vss_agents_ead/
COPY deployments/developer-workflow/dev-profile-ead/install_ead_tools.py /tmp/install_ead_tools.py

# Copy files into the installed package using the container's own Python.
# Exec form is required — the NVIDIA base image does not provide /bin/sh.
RUN ["/vss-agent/.venv/bin/python", "/tmp/install_ead_tools.py"]
